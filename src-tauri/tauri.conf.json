{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Iter",
  "version": "0.1.0",
  "identifier": "org.ludiars.iter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "control-panel",
        "title": "Iter — Control Panel",
        "url": "index.html",
        "width": 380,
        "height": 720,
        "minWidth": 320,
        "minHeight": 480,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
